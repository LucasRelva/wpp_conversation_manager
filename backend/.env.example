# Redis Configuration
REDIS_URL=redis://redis:6379

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# WhatsApp Configuration (Optional)
WHATSAPP_API_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_phone_id_here

# Telegram Configuration (Optional)
TELEGRAM_API_TOKEN=your_telegram_token_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Security (optional in development, strongly recommended in production)
AGENT_API_KEY=change_me_agent_key
WEBHOOK_SECRET=change_me_webhook_secret
AGENT_RATE_LIMIT_PER_MINUTE=120
WEBHOOK_RATE_LIMIT_PER_MINUTE=300
